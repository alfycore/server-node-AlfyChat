# ═══════════════════════════════════════════
# AlfyChat Server Node v2 — Configuration
# ═══════════════════════════════════════════

# ── Credentials (auto-generated on first run) ──
SERVER_ID=
NODE_TOKEN=

# ── Gateway ──
GATEWAY_URL=https://gateway.alfychat.app

# ── Server ──
PORT=4100
DATA_DIR=./alfychat-data

# ── Database ──
# Type: sqlite (default), postgres, mysql
DB_TYPE=sqlite
# For sqlite, DB_NAME is the file path (defaults to DATA_DIR/server.db)
# DB_NAME=./alfychat-data/server.db

# For postgres/mysql:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=alfychat_node
# DB_USER=alfychat
# DB_PASS=secret

# ── Redis (optional, for scaling) ──
REDIS_ENABLED=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASS=

# ── JWT (for direct access / bots) ──
JWT_SECRET=alfychat-node-secret-change-me
JWT_EXPIRES_IN=7d

# ── Logging ──
LOG_LEVEL=info
