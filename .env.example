# =============================================
# AlfyChat Server Node — Configuration
# Copier ce fichier en .env et remplir les valeurs
# Récupérez SERVER_ID et NODE_TOKEN dans les
# paramètres de votre serveur AlfyChat (onglet "Server Node")
# =============================================

# ID du serveur (UUID)
SERVER_ID=

# Token d'authentification du nœud
NODE_TOKEN=

# URL du gateway AlfyChat
GATEWAY_URL=https://gateway.alfychat.app

# Port HTTP local du server-node
PORT=4100

# Dossier de stockage (SQLite + uploads)
DATA_DIR=./alfychat-data
